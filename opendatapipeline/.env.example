# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Copy this file to `.env` in the same directory and fill in the values.
# .env is gitignored and will not be committed.
#
# Priority order: env vars > [llm] ini section > [langchain] ini section > defaults
# =============================================================================

# Provider selection — one of: ollama | openai | anthropic | google | mock
# LLM_PROVIDER=ollama

# Global overrides (apply to any provider unless a provider-specific var exists)
# LLM_MODEL=openhermes
# LLM_TEMPERATURE=0

# --- Ollama (default) --------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=openhermes

# --- OpenAI ------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# --- Anthropic ---------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Google Gemini -----------------------------------------------------------
# Obtain an API key from https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=AIza...
# GOOGLE_MODEL=gemini-2.0-flash
