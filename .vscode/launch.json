{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach to pytest in Docker (debugpy)",
            "type": "python",
            "request": "attach",
            "connect": {
                // if host: "localhost" does not work, you can try host: "host.docker.internal"
                "host": "localhost",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}",
                    "remoteRoot": "/workspace"
                }
            ]
        }
    ]
}